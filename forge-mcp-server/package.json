{
  "name": "forge-mcp-server",
  "version": "0.4.0",
  "description": "MCP server for forge — structured planning, validation, iteration state, logs, and memory tools for Claude Code",
  "type": "module",
  "main": "index.mjs",
  "bin": {
    "forge-mcp": "./index.mjs"
  },
  "scripts": {
    "start": "node index.mjs",
    "test": "node --test tests/*.test.mjs",
    "test:watch": "node --test --watch tests/*.test.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "claude-code",
    "workflow",
    "planning",
    "validation",
    "forge"
  ],
  "author": {
    "name": "TT-Wang",
    "url": "https://github.com/TT-Wang"
  },
  "license": "MIT",
  "homepage": "https://github.com/TT-Wang/forge#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TT-Wang/forge.git",
    "directory": "forge-mcp-server"
  },
  "bugs": {
    "url": "https://github.com/TT-Wang/forge/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0"
  },
  "devDependencies": {
    "eslint": "^10.2.0",
    "prettier": "^3.3.3"
  }
}
